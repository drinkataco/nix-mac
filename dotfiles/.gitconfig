#################################
# USER                          #
#################################
[user]
  name       = J J Walwyn
  username   = drinkataco
  email      = git@jo.shw.al
  signingKey = F78A0E433EB3D6D1


#################################
# CONFIG                        #
#################################
[core]
  fileMode     = true
  eol          = lf
  excludesfile = ~/.gitignore
  editor       = nvim
  pager        = delta
  whitespace   = trailing-space

[blame]
  date = human

[branch]
  autoSetupRebase = always

[diff]
  colorMoved = default
  tool       = nvimdiff
  keepBackup = false

[gpg]
  program = gpg

[init]
  defaultBranch = main

[interactive]
  diffFilter = delta --color-only

[log]
  decorate = auto

[merge]
  tool          = nvimdiff
  conflictstyle = zdiff3
  keepBackup    = false

[pull]
  rebase = true

[pager]
  blame  = delta
  diff   = delta
  log    = delta
  reflog = delta
  show   = delta

[push]
  autoSetupRemote = true
  default         = simple
  followTags      = true

[rebase]
  abbreviateCommands = true

[web]
  browser = firefox

[user]
  useConfigOnly = true

[delta]
  navigate     = true
  light        = false
  line-numbers = true
  syntax-theme = ansi

[rerere]
  enabled = true


###########################################
# REMOTES and URLs                        #
###########################################
[remote "origin"]
  fetch = +refs/pr/*/head:refs/remotes/origin/pr/*

[url "ssh://git@github.com/"]
  insteadOf = https://github.com/


#################################
# ALIAS                         #
# keep specialised helpers only #
#################################
[alias]
  oldest-ancestor = !zsh -c 'diff --old-line-format= --new-line-format= <(git rev-list --first-parent \"${1:-main}\") <(git rev-list --first-parent \"${2:-HEAD}\") | head -1' -
  gdiff = "!f() { nvim -p $(git diff --name-only) +\"tabdo Gdiff $@\" +tabfirst; }; f"

[commit]
  gpgsign = false

[mergetool]
  keepBackup = false


###########################################
# INCLUDES                                #
# Overrides for other repos               #
# with includeIfs rules for work/personal #
###########################################
[include]
  path = ~/.gitlocalconfig
