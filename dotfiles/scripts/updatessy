#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
YES_NO="${SCRIPT_DIR}/yes_no"
REPO_ROOT="${HOME}/projects/nix-mac"

APPROVE_ALL=false
RUN_UPDATE=true

usage() {
  cat <<'EOF'
Usage: updatessy [--approve] [--rebuild-only]

Update this nix-darwin repo and rebuild the current host.

Notes:
  - This repo manages Homebrew through nix-homebrew.
  - This repo manages pnpm itself through nixpkgs.
  - Global pnpm tools are refreshed by Home Manager activation during rebuild.
  - So brew/pnpm updates flow through flake updates and darwin-rebuild.

Options:
  --approve       Skip prompts and approve actions
  --rebuild-only  Rebuild without running `nix flake update`
  --help          Show this help
EOF
}

prompt_or_approve() {
  local question="$1"

  if [[ "${APPROVE_ALL}" == true ]]; then
    return 0
  fi

  "${YES_NO}" "${question}" "y"
}

ensure_nix() {
  if command -v nix >/dev/null 2>&1; then
    return 0
  fi

  if [[ -r /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]]; then
    # shellcheck disable=SC1091
    . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  fi

  command -v nix >/dev/null 2>&1
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --approve)
        APPROVE_ALL=true
        ;;
      --rebuild-only)
        RUN_UPDATE=false
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        echo "Unknown option: $1"
        usage
        exit 1
        ;;
    esac
    shift
  done
}

main() {
  parse_args "$@"

  if ! ensure_nix; then
    echo 'nix not found'
    exit 1
  fi

  if [[ ! -d "${REPO_ROOT}" || ! -f "${REPO_ROOT}/flake.nix" ]]; then
    echo "flake repo not found at ${REPO_ROOT}"
    exit 1
  fi

  local host
  host="$(hostname -s)"

  cd "${REPO_ROOT}"

  if [[ "${RUN_UPDATE}" == true ]]; then
    if prompt_or_approve "Run nix flake update? [Y/n] "; then
      nix flake update
    else
      echo 'Skipping flake update'
    fi
  fi

  if prompt_or_approve "Rebuild nix-darwin for ${host}? [Y/n] "; then
    if command -v darwin-rebuild >/dev/null 2>&1; then
      sudo darwin-rebuild switch --flake ".#${host}"
    else
      sudo nix run nix-darwin/master#darwin-rebuild -- switch --flake ".#${host}"
    fi
  fi
}

main "$@"
