#!/usr/bin/env bash
set -euo pipefail

# Resolve the repo root even when reached through the ~/scripts symlink so the
# make targets run against the checkout rather than the current directory.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="${SOURCE_DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
YES_NO="${SCRIPT_DIR}/yes_no"

# Scopes that can be checked/approved individually.
ALL_SCOPES='nix,pnpm'

APPROVE_ALL=false
APPROVE=''          # comma-separated scopes approved without prompting
CHECK="$ALL_SCOPES" # comma-separated scopes to run
SILENT=false

COLOR_RESET=$'\033[0m'
COLOR_BLUE=$'\033[1;34m'
COLOR_CYAN=$'\033[1;36m'
COLOR_YELLOW=$'\033[1;33m'

#######################################
# Prints a startup banner when stdout is a terminal.
#######################################
print_banner() {
  if [[ ! -t 1 ]]; then
    return 0
  fi

  printf '%b\n' "${COLOR_CYAN}   __  __          __      __                             ${COLOR_RESET}"
  printf '%b\n' "${COLOR_CYAN}  / / / /___  ____/ /___ _/ /____  ____________  __       ${COLOR_RESET}"
  printf '%b\n' "${COLOR_BLUE} / / / / __ \\/ __  / __ \`/ __/ _ \\/ ___/ ___/ / / /    ${COLOR_RESET}"
  printf '%b\n' "${COLOR_BLUE}/ /_/ / /_/ / /_/ / /_/ / /_/  __(__  |__  ) /_/ /        ${COLOR_RESET}"
  printf '%b\n' "${COLOR_YELLOW}\\____/ .___/\\__,_/\\__,_/\\__/\\___/____/____/\\__, / ${COLOR_RESET}"
  printf '%b\n' "${COLOR_YELLOW}    /_/                                   /____/        ${COLOR_RESET}"
  printf '\n'
  printf '%b\n' "Update nix for computer '$(hostname)'"
  echo
  echo '---'
  echo
}

usage() {
  cat <<'EOF'
Usage: updatessy [--check=SCOPES] [--approve=SCOPES] [--approve-all] [--silent]

Update this nix-darwin repo. Scopes are checked in order:
  nix    run `make upgrade` then `make update`
  pnpm   upgrade outdated global pnpm packages

Options:
  --check=SCOPES    Comma-separated scopes to run (default: nix,pnpm)
  --approve=SCOPES  Comma-separated scopes to run without prompting
  --approve-all     Approve every scope without prompting
  --silent          Run non-interactively, no banner or prompts (implies approve)
  --help            Show this help

Examples:
  updatessy --check=nix                      # rebuild only, skip pnpm
  updatessy --approve=nix --check=nix,pnpm   # check nix and pnpm, but only auto approve nix
  updatessy --check=pnpm --approve-all       # upgrade pnpm packages unattended
EOF
}

#######################################
# Checks whether a scope is present in a comma-separated list.
# Arguments:
#   Scope name.
#   Comma-separated list.
# Returns:
#   0 when present, 1 otherwise.
#######################################
in_list() {
  local needle="$1"
  local list="$2"
  [[ ",${list}," == *",${needle},"* ]]
}

#######################################
# Validates that every scope in a list is known.
# Arguments:
#   Comma-separated scope list.
# Outputs:
#   Writes an error and exits on an unknown scope.
#######################################
validate_scopes() {
  local list="$1"
  local scope
  local IFS=','

  for scope in $list; do
    [[ -z "$scope" ]] && continue
    if ! in_list "$scope" "$ALL_SCOPES"; then
      printf 'Unknown scope: %s (valid: %s)\n' "$scope" "$ALL_SCOPES" >&2
      exit 1
    fi
  done
}

#######################################
# Reports whether a scope should be checked.
# Arguments:
#   Scope name.
#######################################
scope_checked() {
  in_list "$1" "$CHECK"
}

#######################################
# Reports whether a scope's actions are pre-approved.
# Arguments:
#   Scope name.
#######################################
scope_approved() {
  [[ "$SILENT" == true || "$APPROVE_ALL" == true ]] && return 0
  in_list "$1" "$APPROVE"
}

#######################################
# Prompts for a scope unless it is pre-approved or running silently.
# Arguments:
#   Scope name.
#   Prompt text.
# Returns:
#   0 to proceed, 1 to skip.
#######################################
confirm_scope() {
  local scope="$1"
  local question="$2"

  if scope_approved "$scope"; then
    return 0
  fi

  "${YES_NO}" "$question" 'y'
}

#######################################
# Runs the nix scope: `make upgrade` then `make update`.
#######################################
update_nix() {
  scope_checked nix || return 0

  if ! confirm_scope nix 'Run make upgrade and make update? [Y/n] '; then
    return 0
  fi

  make upgrade
  make update
}

#######################################
# Runs the pnpm scope: upgrade outdated global packages.
#######################################
update_pnpm() {
  scope_checked pnpm || return 0

  if ! command -v pnpm >/dev/null 2>&1; then
    return 0
  fi

  export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
  export PATH="$PNPM_HOME/bin:$PATH"

  # pnpm outdated exits non-zero when packages are outdated; print the table so
  # the user sees what would change before deciding.
  if pnpm outdated --global; then
    echo 'pnpm global packages up to date'
    return 0
  fi

  if ! confirm_scope pnpm 'Upgrade outdated global pnpm packages? [Y/n] '; then
    return 0
  fi

  pnpm update -g --latest --config.ignore-scripts=false --config.optional=true
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --approve-all) APPROVE_ALL=true ;;
      --approve=*) APPROVE="${1#*=}" ;;
      --check=*) CHECK="${1#*=}" ;;
      --silent) SILENT=true ;;
      --help|-h) usage; exit 0 ;;
      *) printf 'Unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
    esac
    shift
  done

  validate_scopes "$CHECK"
  validate_scopes "$APPROVE"

  cd "$SCRIPT_DIR"
  cd "$(git rev-parse --show-toplevel)"

  if [[ "$SILENT" != true ]]; then
    print_banner
  fi

  update_nix
  update_pnpm
}

main "$@"
