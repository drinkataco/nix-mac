                  "description": "F6+left/right throws window to Amethyst screen 1/2",
                  "manipulators": [
                    {
                      "type": "basic",
                      "from": {
                        "key_code": "left_arrow",
                        "modifiers": {
                          "optional": [
                            "any"
                          ]
                        }
                      },
                      "to": [
                        {
                          "key_code": "w",
                          "modifiers": [
                            "left_control",
                            "left_option",
                            "left_shift"
                          ]
                        }
                      ],
                      "conditions": [
                        {
                          "type": "variable_if",
                          "name": "f6_layer",
                          "value": 1
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "from": {
                        "key_code": "right_arrow",
                        "modifiers": {
                          "optional": [
                            "any"
                          ]
                        }
                      },
                      "to": [
                        {
                          "key_code": "e",
                          "modifiers": [
                            "left_control",
                            "left_option",
                            "left_shift"
                          ]
                        }
                      ],
                      "conditions": [
                        {
                          "type": "variable_if",
                          "name": "f6_layer",
                          "value": 1
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "Use F6 as Amethyst mod1+t (hold for F6 layer)",
                  "manipulators": [
                    {
                      "type": "basic",
                      "from": {
                        "key_code": "f6",
                        "modifiers": {
                          "optional": [
                            "any"
                          ]
                        }
                      },
                      "to": [
                        {
                          "set_variable": {
                            "name": "f6_layer",
                            "value": 1
                          }
                        }
                      ],
                      "to_after_key_up": [
                        {
                          "set_variable": {
                            "name": "f6_layer",
                            "value": 0
                          }
                        }
                      ],
                      "to_if_alone": [
                        {
                          "key_code": "t",
                          "modifiers": [
                            "left_option",
                            "left_shift"
                          ],
                          "lazy": false
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "Use F5 as Amethyst mod1+space",
                  "manipulators": [
                    {
                      "type": "basic",
                      "from": {
                        "key_code": "f5",
                        "modifiers": {
                          "optional": [
                            "any"
                          ]
                        }
                      },
                      "to": [
                        {
                          "key_code": "spacebar",
                          "modifiers": [
                            "left_option"
                            ,
                            "left_shift"
                          ],
                          "lazy": false
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "Use F8 as media play/pause",
                  "manipulators": [
                    {
                      "type": "basic",
                      "from": {
                        "key_code": "f8",
                        "modifiers": {
                          "optional": [
                            "any"
                          ]
                        }
                      },
                      "to": [
                        {
                          "consumer_key_code": "play_or_pause"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            "fn_function_keys": [],
            "simple_modifications": [],
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "ansi"
